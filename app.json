{
  "expo": {
    "name": "OpenCode",
    "slug": "opencode-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "opencode",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.opencode.mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to unlock OpenCode and access your sessions securely."
      }
    },
    "android": {
      "package": "ai.opencode.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-local-authentication"],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
